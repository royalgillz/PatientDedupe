# Build outputs
/build/
**/build/
*.o
*.obj
*.exe
*.out
*.a

# Java
target/
*.class

# Node and frontend
node_modules/
dist/
.vite/

# Synthetic data. Regenerable with Synthea and can be large, so it is not
# committed. Only the fields we match on get loaded into the database.
/data/
**/synthea/output/
/tools/synthea/output/

# OS and editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/

# Synthea runtime jar (large, downloaded locally)
tools/synthea/*.jar

# Emscripten SDK (large, installed locally)
tools/emsdk/

# Engine wasm built from source. The C-ABI build for the JVM is regenerated by the
# FHIR Docker build and by the local em++ step, so the binary is not committed.
fhir/src/main/resources/pdd_engine.wasm

# Local-only Maven JVM options. These hold the WINDOWS-ROOT truststore workaround for
# this machine's intercepting TLS proxy; they must not reach CI or the Linux container
# build, where that truststore type is invalid.
**/.mvn/jvm.config

# Environment files with secrets (DATABASE_URL etc.)
.env
**/.env

# Maven shade plugin byproduct
dependency-reduced-pom.xml

# Analytics snapshots and job output (regenerable)
analytics/data/
